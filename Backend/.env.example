# WhatsApp (Meta Cloud API)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
VERIFY_TOKEN=gramsevak_verify_2024
META_APP_SECRET=
WHATSAPP_OTP_TEMPLATE_NAME=
WHATSAPP_OTP_TEMPLATE_LANG=en_US
WHATSAPP_OTP_TEMPLATE_PARAMS=otp,ttl_minutes

# LLMs
# You can use single key or comma-separated multiple keys per provider.
# Multiple keys are used in-order as fallback with the same model for consistent quality.
#
# Where to get keys:
# Gemini: https://aistudio.google.com/app/apikey
# Groq: https://console.groq.com/keys
# Together: https://api.together.xyz/settings/api-keys
# OpenRouter: https://openrouter.ai/keys
# Sarvam: https://dashboard.sarvam.ai

# Optional: disable Gemini if unstable in your region.
ENABLE_GEMINI=true

GEMINI_API_KEY=
GEMINI_API_KEYS=

GROQ_API_KEY=
GROQ_API_KEYS=

TOGETHER_API_KEY=
TOGETHER_API_KEYS=
TOGETHER_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo-Free

OPENROUTER_API_KEY=
OPENROUTER_API_KEYS=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

SARVAM_API_KEY=
SARVAM_API_KEYS=

# URL Verification APIs (Scam Detection) — optional, graceful degradation if empty
# VirusTotal: https://www.virustotal.com/gui/my-apikey (4 req/min per free key, pool multiple)
# Google Safe Browsing: https://console.cloud.google.com/apis/library/safebrowsing.googleapis.com
VIRUSTOTAL_API_KEY=
VIRUSTOTAL_API_KEYS=
GOOGLE_SAFE_BROWSING_KEY=

# Database + Session
MONGODB_URI=
SESSION_CACHE_DIR=
MEMORY_BUDGET_MB=300
ENABLE_PHASE2_API=true

# Auth
JWT_SECRET=
JWT_EXPIRE_DAYS=30

# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO
